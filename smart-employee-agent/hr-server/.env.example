# HR MCP Server Configuration

# Asgardeo OAuth2 issuer URL (token endpoint)
AUTH_ISSUER=https://api.asgardeo.io/t/<tenant>/oauth2/token

# MCP Client Application's Client ID (audience for MCP tokens)
CLIENT_ID=<mcp-client-app-client-id>

# SPA Application's Client ID (audience for browser REST tokens)
SPA_CLIENT_ID=<spa-app-client-id>

# JWKS endpoint for JWT signature verification
JWKS_URL=https://api.asgardeo.io/t/<tenant>/oauth2/jwks

# Set to "true" to disable SSL verification (dev only)
DISABLE_SSL_VERIFY=false
