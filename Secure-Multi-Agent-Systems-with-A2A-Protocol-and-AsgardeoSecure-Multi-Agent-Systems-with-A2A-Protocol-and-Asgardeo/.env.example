# ============================================================================
# ENVIRONMENT VARIABLES - TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values from Asgardeo

# ============================================================================
# ASGARDEO CONFIGURATION
# ============================================================================
ASGARDEO_ORGANIZATION=your_org_name

# ============================================================================
# ORCHESTRATOR AGENT CREDENTIALS
# ============================================================================
# Application credentials for user authentication
ORCHESTRATOR_CLIENT_ID=your_orchestrator_client_id
ORCHESTRATOR_CLIENT_SECRET=your_orchestrator_client_secret

# ============================================================================
# BOOKING AGENT CREDENTIALS
# ============================================================================
# Agent credentials (for A2A authentication with /authn endpoint)
BOOKING_AGENT_ID=booking_agent_id
BOOKING_AGENT_SECRET=booking_agent_secret

# Application credentials (for token exchange)
BOOKING_AGENT_CLIENT_ID=your_booking_agent_app_id
BOOKING_AGENT_CLIENT_SECRET=your_booking_agent_app_secret

# For JWT validation (same as client_id)
BOOKING_AGENT_APP_ID=your_booking_agent_app_id

# ============================================================================
# TOKEN EXCHANGE APPLICATION CREDENTIALS
# ============================================================================
# Separate Asgardeo application for token exchange (as per documentation)
TOKEN_EXCHANGE_CLIENT_ID=your_token_exchange_app_id
TOKEN_EXCHANGE_CLIENT_SECRET=your_token_exchange_app_secret

# ============================================================================
# RESOURCE IDENTIFIERS
# ============================================================================
# The resource identifier for the booking API
BOOKING_API_RESOURCE=https://api.globalcorp.com/booking

# Backend API URL
BACKEND_API_URL=http://localhost:8002

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# JWT VALIDATION
# ============================================================================
# Asgardeo JWKS endpoint for token validation
JWKS_URI=https://api.asgardeo.io/t/your_org_name/oauth2/jwks

# ============================================================================
# NOTES
# ============================================================================
# 1. Replace all placeholder values with actual credentials from Asgardeo
# 2. Keep this file secure and never commit it to version control
# 3. The BOOKING_AGENT needs both agent credentials AND app credentials
# 4. Ensure MASTER_TOKEN has audiences: [orchestrator_id, booking_agent_id]
# 5. BOOKING_API_TOKEN should have audience: booking_api_resource
