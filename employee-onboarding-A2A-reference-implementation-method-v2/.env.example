# App Settings
APP_HOST=127.0.0.1
APP_PORT=8000
APP_CALLBACK_URL=http://localhost:8000/callback

# WSO2 Identity Server (LOCAL)
ASGARDEO_ORG_NAME=carbon.super
ASGARDEO_BASE_URL=https://localhost:9443
ASGARDEO_TOKEN_URL=https://localhost:9443/oauth2/token
ASGARDEO_AUTHORIZE_URL=https://localhost:9443/oauth2/authorize
ASGARDEO_JWKS_URL=https://localhost:9443/oauth2/jwks

# Orchestrator Application (handles user login + downscopes tokens for agents)
ORCHESTRATOR_CLIENT_ID=
ORCHESTRATOR_CLIENT_SECRET=
ORCHESTRATOR_AGENT_ID=
ORCHESTRATOR_AGENT_SECRET=

# Worker Agent Applications — each agent has its own WSO2 IS Application + Agent identity.
# The Orchestrator uses client_id/secret to downscope the user token (no actor token needed).
# Each agent then uses its OWN client_id/secret (3-step actor token flow) + agent_id/secret
# to prove its identity when doing the second RFC 8693 exchange for calling its downstream API.
HR_CLIENT_ID=
HR_CLIENT_SECRET=
HR_AGENT_ID=
HR_AGENT_SECRET=

IT_CLIENT_ID=
IT_CLIENT_SECRET=
IT_AGENT_ID=
IT_AGENT_SECRET=

PAYROLL_CLIENT_ID=
PAYROLL_CLIENT_SECRET=
PAYROLL_AGENT_ID=
PAYROLL_AGENT_SECRET=

APPROVAL_CLIENT_ID=
APPROVAL_CLIENT_SECRET=
APPROVAL_AGENT_ID=
APPROVAL_AGENT_SECRET=

BOOKING_CLIENT_ID=
BOOKING_CLIENT_SECRET=
BOOKING_AGENT_ID=
BOOKING_AGENT_SECRET=

# MCP IT Server (own WSO2 IS Application + Agent identity)
MCP_IT_CLIENT_ID=
MCP_IT_CLIENT_SECRET=
MCP_IT_AGENT_ID=
MCP_IT_AGENT_SECRET=

# Other
API_AUDIENCE=onboarding-api
OPENAI_API_KEY=

# IT Admin Approval Gate
IT_ADMIN_EMAIL=habdthilakasiri2002@gmail.com
IT_APPROVAL_TIMEOUT=604800           # 7 days in seconds
IT_SERVICE_BASE_URL=http://localhost:8002

# Google Calendar (Booking Agent)
GOOGLE_APPLICATION_CREDENTIALS=./google-service-account.json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# SMTP (optional — approval URL is printed to terminal if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
